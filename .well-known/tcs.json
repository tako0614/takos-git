{
  "schemaVersion": "tcs.repo/v1",
  "id": "takos-git",
  "modulePath": ".",
  "kind": "storage",
  "surface": "service",
  "provider": "cloudflare",
  "category": "developer",
  "suggestedName": "git",
  "name": {
    "ja": "Takos Git",
    "en": "Takos Git"
  },
  "description": {
    "ja": "Git Smart HTTP で使えるリポジトリサービスを公開します。",
    "en": "Deploys a repository service over Git Smart HTTP."
  },
  "badge": {
    "ja": "追加候補",
    "en": "Installable"
  },
  "iconUrl": "public/icons/takos-git.svg",
  "inputs": [
    {
      "name": "project_name",
      "type": "string",
      "format": "text",
      "required": true,
      "defaultValue": "service-name-with-space",
      "label": {
        "ja": "サービス名",
        "en": "Service name"
      }
    },
    {
      "name": "public_subdomain",
      "type": "string",
      "format": "subdomain",
      "required": true,
      "defaultValue": "service-name-with-space",
      "label": {
        "ja": "公開サブドメイン",
        "en": "Public subdomain"
      }
    },
    {
      "name": "public_url",
      "type": "string",
      "format": "url",
      "required": true,
      "label": {
        "ja": "公開URL",
        "en": "Public URL"
      }
    },
    {
      "name": "service_grant_signing_key",
      "type": "string",
      "format": "token",
      "secret": true,
      "advanced": true,
      "label": {
        "ja": "Grant signing key",
        "en": "Grant signing key"
      }
    },
    {
      "name": "worker_bundle_url",
      "type": "string",
      "format": "url",
      "advanced": true,
      "defaultValue": "https://github.com/tako0614/takos-git/releases/download/v0.1.2/worker.js",
      "label": {
        "ja": "Worker artifact URL",
        "en": "Worker artifact URL"
      }
    },
    {
      "name": "worker_bundle_sha256",
      "type": "string",
      "format": "sha256",
      "advanced": true,
      "defaultValue": "be8a48e0e49cb27d1ec34eba7268a3fe57a6826f3549a020153e069e3b2c49db",
      "label": {
        "ja": "Worker artifact SHA-256",
        "en": "Worker artifact SHA-256"
      }
    }
  ],
  "installExperience": {
    "projections": [
      {
        "kind": "service_name",
        "variable": "project_name"
      },
      {
        "kind": "public_endpoint",
        "variables": {
          "subdomain": "public_subdomain",
          "url": "public_url",
          "routePattern": "cloudflare_route_pattern"
        },
        "baseDomain": "app.takos.jp"
      },
      {
        "kind": "initial_secret",
        "variable": "service_grant_signing_key",
        "secretKind": "token",
        "optional": true
      },
      {
        "kind": "artifact",
        "variables": {
          "url": "worker_bundle_url",
          "sha256": "worker_bundle_sha256"
        }
      }
    ]
  },
  "outputAllowlist": [
    {
      "key": "launch_url",
      "from": "launch_url",
      "type": "url"
    },
    {
      "key": "url",
      "from": "url",
      "type": "url"
    },
    {
      "key": "public_url",
      "from": "public_url",
      "type": "url"
    },
    {
      "key": "api_url",
      "from": "api_url",
      "type": "url"
    },
    {
      "key": "app_deployment",
      "from": "app_deployment",
      "type": "json"
    },
    {
      "key": "service_exports",
      "from": "service_exports",
      "type": "json"
    }
  ]
}
