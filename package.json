{
  "name": "takos-git",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "description": "Standalone Git Smart HTTP service (installable Capsule).",
  "license": "AGPL-3.0-only",
  "scripts": {
    "build:worker": "bun run scripts/build-worker.ts",
    "build:web": "cd web && bun run build",
    "build": "bun run build:web && bun run build:worker",
    "dev:web": "cd web && vite",
    "smoke:postdeploy": "bun run scripts/post-deploy-smoke.ts",
    "test": "bun test",
    "check": "bunx tsc --noEmit",
    "check:web": "cd web && tsc --noEmit"
  },
  "dependencies": {
    "yaml": "^2.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
